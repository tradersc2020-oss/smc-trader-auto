{
  "expo": {
    "name": "SMC Trader Auto",
    "slug": "smc-trader-auto",
    "version": "1.0.0",
    "runtimeVersion": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "description": "Desenvolvido por Caiolf",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.smctrader.auto",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Alertas de entrada e horários do mercado"
      }
    },
    "android": {
      "package": "com.smctrader.auto",
      "newArchEnabled": true,
      "icon": "./assets/icon.png",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#FFD700",
          "sounds": []
        }
      ],
      "expo-font"
    ],
    "scheme": "smctraderauto",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {}
    },
    "owner": "caiolf"
  }
}
